{
  "name": "mcp-sitter",
  "version": "0.2.0",
  "description": "Hot-reload bridge for stdio MCP servers. Rebuild your MCP server without restarting the MCP client. Injects restart notices and tools-list diffs into tool/call responses so the AI self-corrects after schema changes.",
  "license": "MIT",
  "author": "Yoshifumi Tsuda",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yotsuda/mcp-sitter.git"
  },
  "homepage": "https://github.com/yotsuda/mcp-sitter",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "hot-reload",
    "dev-tool",
    "proxy",
    "claude",
    "claude-code",
    "ai"
  ],
  "bin": {
    "mcp-sitter": "bin/cli.mjs"
  },
  "files": [
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "optionalDependencies": {
    "@ytsuda/mcp-sitter-win32-x64": "0.2.0",
    "@ytsuda/mcp-sitter-linux-x64": "0.2.0",
    "@ytsuda/mcp-sitter-darwin-arm64": "0.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
