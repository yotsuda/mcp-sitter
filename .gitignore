## .NET build output
bin/
obj/
*.user
*.suo
*.userprefs
.vs/
.vscode/

## npm package bin/ exceptions:
## - npm/bin/         : the umbrella's cli.mjs wrapper, always tracked
## - npm/platforms/*/bin/.gitkeep : keep the subpackage bin/ dirs
##   around in source so the scaffold doesn't drift, but never ship
##   binaries in git. CI builds + (for Windows) Authenticode-signs
##   the binaries on the runner and publishes from the runner's
##   working tree.
!npm/bin/
!npm/bin/**
!npm/platforms/*/bin/
!npm/platforms/*/bin/.gitkeep

## npm pack artifacts
*.tgz

## JetBrains Rider
.idea/
*.sln.iml

## OS
Thumbs.db
.DS_Store
desktop.ini

## Test artifacts
test/FakeMcp/bin/
test/FakeMcp/obj/
test/FakeMcp/bin/Debug/net9.0/toolset.txt

## Session scratch / handoff notes
scratch/

## Root AOT publish output (Build.ps1 mirrors the signed exe into npm/dist/
## which IS tracked, so CI has the release artifact without re-signing)
/dist/
