## .NET build output
bin/
obj/
*.user
*.suo
*.userprefs
.vs/
.vscode/

## npm package bin/ exceptions:
## - npm/bin/         : the umbrella's cli.mjs wrapper, always tracked
## - npm/platforms/win32-x64/bin/ : signed Win exe is committed (PFX
##   never touches CI; sign locally via .\Build.ps1 -Sign).
## Other platform bin dirs (linux/macOS) stay ignored — CI builds them
## fresh per runner and publishes from the runner's working tree.
!npm/bin/
!npm/bin/**
!npm/platforms/win32-x64/bin/
!npm/platforms/win32-x64/bin/**

## JetBrains Rider
.idea/
*.sln.iml

## OS
Thumbs.db
.DS_Store
desktop.ini

## Test artifacts
test/FakeMcp/bin/
test/FakeMcp/obj/
test/FakeMcp/bin/Debug/net9.0/toolset.txt

## Session scratch / handoff notes
scratch/

## Root AOT publish output (Build.ps1 mirrors the signed exe into npm/dist/
## which IS tracked, so CI has the release artifact without re-signing)
/dist/
